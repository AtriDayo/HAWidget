<Window x:Class="HAWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HAWidget 控制台"
        Width="360"
        Height="220"
        WindowStartupLocation="CenterScreen"
        Background="#FF202020">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="HAWidget 控制台"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="StatusText"
                       Text="正在准备窗口..."
                       Foreground="#CCCCCC"
                       FontSize="14"
                       Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal">

                <Button Content="打开设置"
                        Width="120"
                        Height="36"
                        Margin="0,0,10,0"
                        Click="SettingsButton_Click"/>

                <Button Content="重新加载窗口"
                        Width="120"
                        Height="36"
                        Click="ReloadButton_Click"/>

            </StackPanel>

        </StackPanel>
    </Grid>
</Window>