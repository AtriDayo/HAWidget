<Window x:Class="HAWidget.WindowGroupEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑窗口组"
        Height="620"
        Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#FF202020">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="窗口标题"
                       Foreground="White"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="TitleTextBox" Height="32"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock Text="窗口等级"
                       Foreground="White"
                       Margin="0,0,0,6"/>
            <ComboBox x:Name="WindowLevelComboBox">
                <ComboBoxItem Content="置顶" Tag="TopMost"/>
                <ComboBoxItem Content="普通" Tag="Normal"/>
                <ComboBoxItem Content="置底（未实现）" Tag="Bottom"/>
            </ComboBox>
        </StackPanel>

        <UniformGrid Grid.Row="2" Columns="2" Margin="0,14,0,0">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="左边距" Foreground="White" Margin="0,0,0,6"/>
                <TextBox x:Name="LeftTextBox" Height="32"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="上边距" Foreground="White" Margin="0,0,0,6"/>
                <TextBox x:Name="TopTextBox" Height="32"/>
            </StackPanel>
        </UniformGrid>

        <UniformGrid Grid.Row="3" Columns="2" Margin="0,14,0,0">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="窗口宽度" Foreground="White" Margin="0,0,0,6"/>
                <TextBox x:Name="WidthTextBox" Height="32"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="窗口高度" Foreground="White" Margin="0,0,0,6"/>
                <TextBox x:Name="HeightTextBox" Height="32"/>
            </StackPanel>
        </UniformGrid>

        <TextBlock Grid.Row="5"
                   Text="传感器列表"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="Bold"/>

        <ListBox x:Name="SensorListBox"
                 Grid.Row="6"
                 Margin="0,10,0,0"
                 DisplayMemberPath="Title"/>

        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="添加传感器"
                    Width="100"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="AddSensorButton_Click"/>

            <Button Content="编辑传感器"
                    Width="100"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="EditSensorButton_Click"/>

            <Button Content="删除传感器"
                    Width="100"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="DeleteSensorButton_Click"/>

            <Button Content="确定"
                    Width="80"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="OkButton_Click"/>

            <Button Content="取消"
                    Width="80"
                    Height="32"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>