<Window x:Class="HAWidget.SensorEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑实体"
        Height="360"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="标题"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="TitleTextBox"
                     Height="32"/>
        </StackPanel>

        <!-- 实体 ID -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="实体 ID"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="EntityIdTextBox"
                     Height="32"/>
        </StackPanel>

        <!-- 自定义单位 -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="自定义单位"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="UnitTextBox"
                     Height="32"/>
        </StackPanel>

        <!-- 设备类型 -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="设备类型"
                       Margin="0,0,0,6"/>
            <ComboBox x:Name="EntityTypeComboBox"
                      Height="32"
                      SelectedIndex="0">
                <ComboBoxItem Content="传感器" Tag="Sensor"/>
                <ComboBoxItem Content="灯" Tag="Light"/>
                <ComboBoxItem Content="风扇" Tag="Fan"/>
                <ComboBoxItem Content="空调" Tag="Climate"/>
            </ComboBox>
        </StackPanel>

        <!-- 按钮区 -->
        <StackPanel Grid.Row="9"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="取消"
                    Width="90"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="确定"
                    Width="90"
                    Height="32"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>