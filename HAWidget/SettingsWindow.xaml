<Window x:Class="HAWidget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="520"
        Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#FF202020">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Home Assistant 地址"
                       Foreground="White"
                       FontSize="14"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="HaUrlTextBox"
                     Height="32"
                     FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock Text="长期访问令牌 Token"
                       Foreground="White"
                       FontSize="14"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="TokenTextBox"
                     Height="32"
                     FontSize="14"/>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Text="窗口组"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="Bold"/>

        <ListBox x:Name="WindowGroupListBox"
                 Grid.Row="4"
                 Margin="0,10,0,0"
                 DisplayMemberPath="Title"/>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="添加窗口组"
                    Width="100"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="AddGroupButton_Click"/>

            <Button Content="编辑窗口组"
                    Width="100"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="EditGroupButton_Click"/>

            <Button Content="删除窗口组"
                    Width="100"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="DeleteGroupButton_Click"/>

            <Button Content="保存"
                    Width="80"
                    Height="32"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>