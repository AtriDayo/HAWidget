<Window x:Class="HAWidget.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="WidgetWindow"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="进入编辑模式" Click="EnterEditModeMenuItem_Click"/>
            <MenuItem Header="退出编辑模式" Click="ExitEditModeMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="关闭此窗口" Click="CloseWindowMenuItem_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Grid>
        <Border x:Name="RootBorder"
                CornerRadius="20"
                Background="#DD202020"
                Padding="20"
                BorderBrush="Transparent"
                BorderThickness="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="GroupTitleText"
                               Text="窗口组"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <ItemsControl x:Name="EntityItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#22333333"
                                        CornerRadius="14"
                                        Padding="14"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontSize="18"
                                                   FontWeight="Bold"/>

                                        <TextBlock Text="{Binding Value}"
                                                   Foreground="White"
                                                   FontSize="28"
                                                   Margin="0,8,0,4"/>

                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="#CCCCCC"
                                                   FontSize="12"/>
                                        
                                        <StackPanel Orientation="Horizontal"
                                                Margin="0,8,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Config.EntityType}" Value="Light">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <Button Content="开"
                                                Width="60"
                                                Margin="0,0,8,0"
                                                Click="LightOnButton_Click"
                                                Tag="{Binding}" />

                                            <Button Content="关"
                                                Width="60"
                                                Click="LightOffButton_Click"
                                                Tag="{Binding}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>
        <primitives:Thumb x:Name="ResizeThumb"
              Width="22"
              Height="22"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,10,10"
              Cursor="SizeNWSE"
              DragDelta="ResizeThumb_DragDelta"
              Visibility="Collapsed"
              Panel.ZIndex="100">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="#66000000"
                    CornerRadius="6"
                    BorderBrush="#66FFFFFF"
                    BorderThickness="1">
                        <Canvas Width="22" Height="22">
                            <Line X1="8" Y1="18" X2="18" Y2="8"
                                  Stroke="White"
                                  StrokeThickness="1.6"
                                  Opacity="0.9"/>
                                                    <Line X1="11" Y1="18" X2="18" Y2="11"
                                  Stroke="White"
                                  StrokeThickness="1.6"
                                  Opacity="0.75"/>
                                                    <Line X1="14" Y1="18" X2="18" Y2="14"
                                  Stroke="White"
                                  StrokeThickness="1.6"
                                  Opacity="0.6"/>
                        </Canvas>
                    </Border>
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
    </Grid>
</Window>